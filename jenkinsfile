pipeline {
   agent any
   stages {
      stage('build') {
          steps {
              echo 'building the application'
           }
       }
      stage('test') {
          steps {
              echo 'running tests'
           }
       }
      stage('deploy') {
          steps {
              echo 'deploying the application'
           }
       }
   }
   post {
      success {
          bat 'echo build successful'
       }
      failure {
          bat 'echo build failed'
       }
   }
}