pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/Dhruv593/Jenkins-Demo-ML-Model.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker-compose build'
            }
        }

        stage('Test') {
            steps {
                echo 'running tests'
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker-compose up -d'
            }
        }
    }

    post {
        success {
            echo 'Build Successful'
        }
        failure {
            echo 'Build Failed'
        }
    }
}