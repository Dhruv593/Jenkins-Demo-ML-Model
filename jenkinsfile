pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                echo 'building the application'
            }
        }

        stage('Test') {
            steps {
                echo 'running tests'
            }
        }

        stage('Deploy') {
            steps {
                echo 'deploying the application'
            }
        }
    }

    post {
        success {
            echo 'Build Successful'
        }
        failure {
            echo 'Build Failed'
        }
    }
}

